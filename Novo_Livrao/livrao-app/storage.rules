rules_version = '2';

// Firebase Storage Security Rules
// Permite que usuários autenticados façam upload/leitura apenas em suas próprias pastas
service firebase.storage {
  match /b/{bucket}/o {
    
    // Regra para uploads da família
    // Cada usuário só pode acessar arquivos na pasta familias/{seu_uid}/
    match /familias/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regra adicional para arquivos públicos (se necessário no futuro)
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
