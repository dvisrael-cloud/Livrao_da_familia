rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- FUNÇÕES AUXILIARES ---
    
    // Verifica se é imagem válida
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    
    // Verifica se tamanho é aceitável (máximo 10MB)
    function isValidSize() {
      return request.resource.size < 10 * 1024 * 1024;
    }
    
    // Verifica se é áudio válido
    function isAudio() {
      return request.resource.contentType.matches('audio/.*');
    }
    
    // Verifica se é vídeo válido  
    function isVideo() {
      return request.resource.contentType.matches('video/.*');
    }
    
    // Verifica se é documento válido (PDF, DOC, etc)
    function isDocument() {
      return request.resource.contentType.matches('application/pdf') ||
             request.resource.contentType.matches('application/msword') ||
             request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.*');
    }
    
    // --- REGRAS POR CAMINHO ---
    
    // Fotos de perfil (selfie) - users/{uid}/profile_pic.jpg
    match /users/{userId}/profile_pic.jpg {
      // Leitura: pública (para exibir foto de perfil)
      allow read: if true;
      
      // Escrita: apenas o próprio usuário
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      isImage() &&
                      isValidSize();
    }
    
    // Galeria de fotos de membros - familias/{uid}/gallery/{photoId}
    match /familias/{userId}/gallery/{photoId} {
      // Leitura: próprio usuário ou autenticado (para compartilhamento)
      allow read: if request.auth != null;
      
      // Escrita: apenas o próprio usuário
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      isImage() &&
                      isValidSize();
    }
    
    // Documentos - familias/{uid}/documents/{docId}
    match /familias/{userId}/documents/{docId} {
      // Leitura: apenas o próprio usuário
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Escrita: apenas o próprio usuário
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      (isImage() || isDocument()) &&
                      isValidSize();
    }
    
    // Vídeos - familias/{uid}/videos/{videoId}
    match /familias/{userId}/videos/{videoId} {
      // Leitura: apenas o próprio usuário
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Escrita: apenas o próprio usuário, limite de 50MB para vídeos
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      isVideo() &&
                      request.resource.size < 50 * 1024 * 1024;
    }
    
    // Áudios - familias/{uid}/audios/{audioId}
    match /familias/{userId}/audios/{audioId} {
      // Leitura: apenas o próprio usuário
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Escrita: apenas o próprio usuário, limite de 20MB para áudios
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      isAudio() &&
                      request.resource.size < 20 * 1024 * 1024;
    }
    
    // Community/Shared - familias/{uid}/community/{fileId}
    match /familias/{userId}/community/{fileId} {
      // Leitura: qualquer usuário autenticado (compartilhamento entre famílias)
      allow read: if request.auth != null;
      
      // Escrita: apenas o próprio usuário
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      (isImage() || isDocument()) &&
                      isValidSize();
    }
    
    // Bloqueia qualquer outro caminho não especificado
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
